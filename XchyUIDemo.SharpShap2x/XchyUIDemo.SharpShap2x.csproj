<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Silk.NET.GLFW" Version="2.22.0" />
    <PackageReference Include="SkiaSharp" Version="2.88.6" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="XchyUI">
      <HintPath>libs\XchyUI.dll</HintPath>
    </Reference>
    <Reference Include="XchyUI.GLFW.Skia2x">
      <HintPath>libs\XchyUI.GLFW.Skia2x.dll</HintPath>
    </Reference>
    <Reference Include="XchyUI.SkiaSharp2x">
      <HintPath>libs\XchyUI.SkiaSharp2x.dll</HintPath>
    </Reference>
  </ItemGroup>

</Project>
